{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AoE2 RMS",
  "scopeName": "source.aoe2-rms",
  "fileTypes": ["rms", "rms2", "def", "inc", "bina"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#section" },
    { "include": "#controlFlow" },
    { "include": "#rnd" },
    { "include": "#command" },
    { "include": "#attribute" },
    { "include": "#baseTerrainCommand" },
    { "include": "#block" },
    { "include": "#macro" },
    { "include": "#number" },
    { "include": "#operator" },
    { "include": "#identifier" }
  ],
  "repository": {

    "comment": {
      "name": "comment.block.aoe2-rms",
      "begin": "/\\*(?=\\s)",
      "end": "\\*/",
      "patterns": [
        { "include": "#comment" }
      ]
    },

    "keyword": {
      "patterns": [
        {
          "comment": "#const NAME — value expression follows and is tokenized normally",
          "match": "(#const)\\s+(\\S+)",
          "captures": {
            "1": { "name": "keyword.other.aoe2-rms" },
            "2": { "name": "variable.other.constant.aoe2-rms" }
          }
        },
        {
          "comment": "#define NAME",
          "match": "(#define)\\s+(\\S+)",
          "captures": {
            "1": { "name": "keyword.other.aoe2-rms" },
            "2": { "name": "variable.other.constant.aoe2-rms" }
          }
        },
        {
          "comment": "#include_drs or #includeXS with a quoted filepath (spaces allowed inside)",
          "name": "meta.include.aoe2-rms",
          "begin": "(#include_drs|#includeXS)\\s+(\")",
          "end": "\"",
          "beginCaptures": {
            "1": { "name": "keyword.other.aoe2-rms" },
            "2": { "name": "punctuation.definition.string.begin.aoe2-rms" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.aoe2-rms" }
          },
          "contentName": "string.quoted.double.aoe2-rms",
          "patterns": [
            { "include": "#escape" }
          ]
        },
        {
          "comment": "#include_drs or #includeXS with an unquoted filepath (no spaces)",
          "match": "(#include_drs|#includeXS)\\s+(\\S+)",
          "captures": {
            "1": { "name": "keyword.other.aoe2-rms" },
            "2": { "name": "string.unquoted.aoe2-rms" }
          }
        },
        {
          "comment": "Bare keyword with no arguments yet typed",
          "match": "#const|#define|#include_drs|#includeXS",
          "name": "keyword.other.aoe2-rms"
        }
      ]
    },

    "escape": {
      "match": "\\\\\\S",
      "name": "constant.character.escape.aoe2-rms"
    },

    "section": {
      "match": "<(PLAYER_SETUP|LAND_GENERATION|ELEVATION_GENERATION|CLIFF_GENERATION|TERRAIN_GENERATION|CONNECTION_GENERATION|OBJECTS_GENERATION)>",
      "name": "entity.name.tag.aoe2-rms"
    },

    "controlFlow": {
      "match": "\\b(if|elseif|else|endif|start_random|percent_chance|end_random)\\b",
      "name": "keyword.control.aoe2-rms"
    },

    "rnd": {
      "comment": "rnd(int,int) built-in function",
      "match": "\\b(rnd)\\s*(\\()\\s*([+-]?[0-9]+)\\s*(,)\\s*([+-]?[0-9]+)\\s*(\\))",
      "captures": {
        "1": { "name": "entity.name.function.aoe2-rms" },
        "2": { "name": "punctuation.section.group.begin.aoe2-rms" },
        "3": { "name": "constant.numeric.integer.aoe2-rms" },
        "4": { "name": "punctuation.separator.aoe2-rms" },
        "5": { "name": "constant.numeric.integer.aoe2-rms" },
        "6": { "name": "punctuation.section.group.end.aoe2-rms" }
      }
    },

    "command": {
      "comment": "Built-in command names.",
      "match": "\\b(random_placement|direct_placement|grouped_by_team|nomad_resources|force_nomad_treaty|behavior_version|override_map_size|set_gaia_civilization|ai_info_map_type|effect_amount|effect_percent|guard_state|terrain_state|weather_type|water_definition|enable_waves|create_player_lands|create_land|create_elevation|color_correction|create_terrain|cliff_type|min_number_of_cliffs|max_number_of_cliffs|min_length_of_cliff|max_length_of_cliff|cliff_curliness|min_distance_cliffs|min_terrain_distance|accumulate_connections|create_connect_all_players_land|create_connect_teams_lands|create_connect_all_lands|create_connect_same_land_zones|create_connect_land_zones|create_connect_to_nonplayer_land|create_actor_area|create_object_group|create_object)\\b",
      "name": "entity.name.function.aoe2-rms"
    },

    "baseTerrainCommand": {
      "comment": "base_terrain and base_layer as commands at the top level.",
      "match": "\\b(base_terrain|base_layer)\\b",
      "name": "entity.name.function.aoe2-rms"
    },

    "baseTerrainAttribute": {
      "comment": "base_terrain and base_layer as attributes inside a block.",
      "match": "\\b(base_terrain|base_layer)\\b",
      "name": "variable.other.property.aoe2-rms"
    },

    "attribute": {
      "comment": "Built-in attribute names.",
      "match": "\\b(terrain_type|land_percent|number_of_tiles|base_size|set_circular_base|generate_mode|land_position|circle_radius|left_border|right_border|top_border|bottom_border|border_fuzziness|clumping_factor|land_conformity|base_elevation|assign_to_player|assign_to|zone|set_zone_by_team|set_zone_randomly|other_zone_avoidance_distance|min_placement_distance|land_id|number_of_clumps|set_scale_by_size|set_scale_by_groups|spacing|enable_balanced_elevation|beach_terrain|terrain_mask|spacing_to_other_terrain_types|spacing_to_specific_terrain|set_flat_terrain_only|set_avoid_player_start_areas|height_limits|default_terrain_replacement|replace_terrain|terrain_cost|terrain_size|add_object|number_of_objects|number_of_groups|group_variance|group_placement_radius|set_tight_grouping|set_loose_grouping|min_connected_tiles|resource_delta|second_object|set_scaling_to_map_size|set_scaling_to_player_number|set_place_for_every_player|place_on_specific_land_id|avoid_other_land_zones|generate_for_first_land_only|set_gaia_object_only|set_gaia_unconvertible|set_building_capturable|make_indestructible|min_distance_to_players|max_distance_to_players|set_circular_placement|terrain_to_place_on|layer_to_place_on|ignore_terrain_restrictions|max_distance_to_other_zones|place_on_forest_zone|avoid_forest_zone|avoid_cliff_zone|min_distance_to_map_edge|min_distance_group_placement|temp_min_distance_group_placement|find_closest|find_closest_to_map_center|find_closest_to_map_edge|enable_tile_shuffling|require_path|force_placement|actor_area|actor_area_radius|override_actor_radius_if_required|actor_area_to_place_in|avoid_actor_area|avoid_all_actor_areas|set_facet|match_player_civ)\\b",
      "name": "variable.other.property.aoe2-rms"
    },

    "block": {
      "comment": "A { } block. Inside this context base_terrain/base_layer become properties instead of commands.",
      "begin": "(?<!\\S)\\{(?!\\S)",
      "end": "(?<!\\S)\\}(?!\\S)",
      "beginCaptures": { "0": { "name": "punctuation.section.block.begin.aoe2-rms" } },
      "endCaptures":   { "0": { "name": "punctuation.section.block.end.aoe2-rms" } },
      "patterns": [
        { "include": "#comment" },
        { "include": "#keyword" },
        { "include": "#controlFlow" },
        { "include": "#rnd" },
        { "include": "#command" },
        { "include": "#baseTerrainAttribute" },
        { "include": "#attribute" },
        { "include": "#block" },
        { "include": "#macro" },
        { "include": "#number" },
        { "include": "#operator" },
        { "include": "#identifier" }
      ]
    },

    "macro": {
      "comment": "Uppercase preprocessor macros such as #TCBOXES, #OBJECTS9VILS, etc.",
      "match": "#[A-Z0-9_]+",
      "name": "meta.preprocessor.macro.aoe2-rms"
    },

    "number": {
      "patterns": [
        {
          "comment": "Floating-point numbers including inf",
          "match": "[+-]?(inf|[0-9]*\\.[0-9]+)",
          "name": "constant.numeric.float.aoe2-rms"
        },
        {
          "comment": "Integer literals, optionally signed",
          "match": "[+-]?[0-9]+",
          "name": "constant.numeric.integer.aoe2-rms"
        }
      ]
    },

    "operator": {
      "match": "(?<=\\s)[+\\-*/%](?=\\s)",
      "name": "keyword.operator.aoe2-rms"
    },

    "identifier": {
      "comment": "Fallback for user-defined constants, terrain names, unit names, etc.",
      "match": "[\\w'#$*\\-\\{\\}\\[\\]<>/]+",
      "name": "variable.other.constant.aoe2-rms"
    }

  }
}